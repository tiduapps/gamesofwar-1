{
	"name": "gamesofwar",
	"private": true,
	"type": "module",
	"scripts": {
		"images:extract": "node --env-file=scripts/.env scripts/extract-images.mjs",
		"images:migrate": "node --env-file=scripts/.env scripts/migrate-images-to-supabase.mjs",
		"images:migrate:dry-run": "node scripts/migrate-images-to-supabase.mjs --dry-run",
